<div style="padding:20px; display:grid; gap:20px;">

    {# Change Form #}
    <form method="POST" action="{{ path('change-create') }}" style="border:1px solid #ccc; padding:15px; border-radius:10px;">
        <h2>Change</h2>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('service') }}">

        <div style="display:grid; gap:10px;">
            <input
                type="number"
                name="quantity"
                placeholder="Quantity"
                required
            />

            <input
                type="float"
                name="amount"
                placeholder="Amount"
                required
            />
        </div>

        <button type="submit" style="margin-top:10px;">Guardar Change</button>
    </form>

    {# Product Form #}
    <form method="POST" action="{{ path('product-create') }}" style="border:1px solid #ccc; padding:15px; border-radius:10px;">
        <h2>Product</h2>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token('service') }}">

        <div style="display:grid; gap:10px;">
            <input
                type="text"
                name="code"
                placeholder="Code"
                required
            />

            <input
                type="text"
                name="name"
                placeholder="Name"
                required
            />

            <input
                type="number"
                step="0.01"
                name="price"
                placeholder="Price"
                required
            />

            <input
                type="number"
                name="quantity"
                placeholder="Quantity"
                required
            />
        </div>

        <button type="submit" style="margin-top:10px;">Guardar Product</button>
    </form>

    <hr>

<h2>Stock de Productos</h2>
<table border="1" cellpadding="5" cellspacing="0">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Cantidad</th>
        </tr>
    </thead>
    <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.code }}</td>
                <td>{{ product.name }}</td>
                <td>{{ product.price }} {{ product.currency }}</td>
                <td>{{ product.quantity }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">No hay productos</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

<hr>

<h2>Stock de Cambio</h2>
<table border="1" cellpadding="5" cellspacing="0">
    <thead>
        <tr>
            <th>Moneda</th>
            <th>Valor</th>
            <th>Cantidad</th>
        </tr>
    </thead>
    <tbody>
        {% for coin in change %}
            <tr>
                <td>{{ coin.currency }}</td>
                <td>{{ coin.amount }}</td>
                <td>{{ coin.quantity }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">No hay cambio disponible</td>
            </tr>
        {% endfor %}
    </tbody>
</table>

    {# Logout Button #}
    <form method="POST" action="{{ path('logout') }}" style="margin-top:10px;">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('service') }}">

        <button type="submit" style="background:#e53e3e; color:white; padding:10px; border:none; border-radius:8px;">
            Logout
        </button>
    </form>

</div>