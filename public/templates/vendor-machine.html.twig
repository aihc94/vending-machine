<meta name="csrf-token" content="{{ csrf_token('ajax') }}">

<input type="number" id="money" step="0.01" min="0" required>

<div id="validationMessage" style="color: red; font-size: 0.9em;"></div>

<br><br>

<button onclick="addMoney()">Guardar dinero</button>

<br><br>

{% for product in products %}
    <div style="margin-bottom: 10px;">
        <button onclick="purchase('{{ product.code }}')">
            {{ product.name }}
        </button>
        <div style="font-size: 0.9em;">
            Precio: {{ product.price }} {{ product.currency }}<br>
            Stock: {{ product.quantity }}
        </div>
    </div>
{% endfor %}

<br><br>

<button onclick="closePurchase()">Close Purchase</button>

<hr>

<p>Identifier: <span id="identifier">{{ purchase.identifier }}</span></p>
<p>Total Amount: <span id="totalAmount">{{ purchase.totalAmount }}</span></p>
<p>Restart Purchase: <span id="restartPurchase">{{ purchase.restartPurchase ? 'Yes' : 'No' }}</span></p>

<h3>Debug</h3>
<pre>
    Products:
    {{ dump(products) }}

    Change:
    {{ dump(change) }}
</pre>

<script src="{{ asset('js/purchase.js') }}"></script>