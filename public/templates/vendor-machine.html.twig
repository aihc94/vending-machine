<link rel="stylesheet" href="{{ asset('css/vending.css') }}">
<div class="vending">

    <div class="screen">
        <input type="number" id="money" step="0.01" min="0" required>
        <div id="validationMessage"></div>
        <button onclick="addMoney()">Guardar dinero</button>
    </div>

    <div class="products">
        {% for product in products %}
            <div class="product">
                <button onclick="purchase('{{ product.code }}')">
                    {{ product.name }}
                </button>
                <div class="small-text">
                    {{ product.price }} {{ product.currency }}<br>
                    Stock: {{ product.quantity }}
                </div>
            </div>
        {% endfor %}
    </div>

    <br>

    <div id="validationPurchaseMessage"></div>

    <button onclick="closePurchase()">Finalizar compra</button>

    <hr>

    <div class="screen">
        <p>ID: <span id="identifier">{{ purchase.identifier }}</span></p>
        <p>Total: <span id="totalAmount">{{ purchase.totalAmount }}</span></p>
    </div>

    <h3>Change</h3>

    <div class="change-box">
        {% if change is defined and change|length > 0 %}
            <ul>
                {% for coin in change %}
                    <li>
                        {{ coin.quantity }} x {{ coin.amount }} {{ coin.currency }}
                        {% if coin.quantity == 0 %}
                            <span style="color:#777">(sin stock)</span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        {% else %}
            <p>No hay cambio disponible</p>
        {% endif %}
    </div>

</div>

<div id="purchaseModal" style="
    display:none;
    position:fixed;
    top:0; left:0;
    width:100%; height:100%;
    background:rgba(0,0,0,0.7);
    justify-content:center;
    align-items:center;
">
    <div class="modal-box">
        <h2>Compra realizada</h2>

        <p><strong>Producto:</strong></p>
        <pre id="modalProduct"></pre>

        <p><strong>Cambio:</strong></p>
        <div id="modalChange" class="change-box"></div>

        <p><strong>Historial:</strong></p>
        <div id="modalHistory" class="change-box"></div>

        <button onclick="reloadPage()">Recargar</button>
    </div>
</div>

<meta name="csrf-token" content="{{ csrf_token('ajax') }}">
<script src="{{ asset('js/purchase.js') }}"></script>