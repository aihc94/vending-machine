<meta name="csrf-token" content="{{ csrf_token('ajax') }}">

<input type="number" id="money" step="0.01" min="0" required>

<div id="validationMessage" style="color: red; font-size: 0.9em;"></div>

<br><br>

<button onclick="addMoney()">Guardar dinero</button>

<br><br>

{% for product in products %}
    <div style="margin-bottom: 10px;">
        <button onclick="purchase('{{ product.code }}')">
            {{ product.name }}
        </button>
        <div style="font-size: 0.9em;">
            Precio: {{ product.price }} {{ product.currency }}<br>
            Stock: {{ product.quantity }}
        </div>
    </div>
{% endfor %}

<br><br>

<div id="validationPurchaseMessage" style="color: red; font-size: 0.9em;"></div>

<button onclick="closePurchase()">Close Purchase</button>

<hr>

<p>Identifier: <span id="identifier">{{ purchase.identifier }}</span></p>
<p>Total Amount: <span id="totalAmount">{{ purchase.totalAmount }}</span></p>
<p>Restart Purchase: <span id="restartPurchase">{{ purchase.restartPurchase ? 'Yes' : 'No' }}</span></p>

<div id="purchaseModal" style="
    display:none;
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.5);
    justify-content:center;
    align-items:center;
">
    <div style="
        background:white;
        padding:20px;
        border-radius:8px;
        min-width:300px;
        text-align:left;
    ">
        <h2>Compra realizada</h2>

        <p><strong>Producto:</strong></p>
        <pre id="modalProduct"></pre>

        <p><strong>Cambio:</strong></p>
        <div id="modalChange" style="
            max-height: 150px;
            overflow-y: auto;
            border: 1px solid #ccc;
            padding: 8px;
            background: #f9f9f9;
            font-size: 14px;
        "></div>

        <p><strong>Historial:</strong></p>
        <div id="modalHistory" style="
            max-height: 150px;
            overflow-y: auto;
            border: 1px solid #ccc;
            padding: 8px;
            background: #f9f9f9;
            font-size: 14px;
        "></div>

        <button onclick="reloadPage()">Recargar página</button>
    </div>
</div>

<script src="{{ asset('js/purchase.js') }}"></script>