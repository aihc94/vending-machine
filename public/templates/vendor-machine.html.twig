<form method="post" action="">
    
    <div>
        <label for="money">Cantidad de dinero:</label>
        <input 
            type="number" 
            id="money" 
            name="money" 
            step="0.01" 
            min="0" 
            required
        >
    </div>

    <br>

    <div>
        <button type="submit" name="action" value="product1">
            Purchase Producto 1
        </button>

        <button type="submit" name="action" value="product2">
            Purchase Producto 2
        </button>

        <button type="submit" name="action" value="product3">
            Purchase Producto 3
        </button>
    </div>

    <br>

    <div>
        <button type="submit" name="action" value="close">
            Close Purchase
        </button>
    </div>

</form>