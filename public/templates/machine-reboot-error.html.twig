<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Error de máquina</title>
</head>
<body style="font-family: Arial, sans-serif; margin:0;">

    {# HEADER ERROR #}
    <div style="
        background:#b30000;
        color:white;
        padding:20px;
        text-align:center;
        font-size:20px;
        font-weight:bold;
    ">
        ⚠️ REBOOT MACHINE ERROR
    </div>

    {# CONTENIDO #}
    <div style="padding:20px;">
        <p>Se ha producido un error en la máquina. Detalles de la última operación:</p>
    </div>

    {# MODAL SIEMPRE VISIBLE (sin JS) #}
    <div style="
        display:flex;
        position:fixed;
        top:0;
        left:0;
        width:100%;
        height:100%;
        background:rgba(0,0,0,0.5);
        justify-content:center;
        align-items:center;
    ">
        <div style="
            background:white;
            padding:20px;
            border-radius:8px;
            min-width:300px;
            text-align:left;
        ">
            <h2>Estado de la operación</h2>

            <p><strong>Cambio:</strong></p>
            <div style="
                max-height: 150px;
                overflow-y: auto;
                border: 1px solid #ccc;
                padding: 8px;
                background: #f9f9f9;
                font-size: 14px;
            ">
{{ {
    message: 'Money inserted by client returned. Displays the amount and the repetition is the quantity',
    amount: change
}|json_encode(constant('JSON_PRETTY_PRINT')) }}
            </div>

            <button onclick="window.location.reload()">Recargar página</button>
        </div>
    </div>

</body>
</html>